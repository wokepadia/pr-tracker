{
  "name": "@pr-tracker/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "migrate:up": "tsx src/migrate.ts",
    "seed:sample": "tsx src/seed-sample.ts",
    "smoke:ingest": "tsx src/ingest-smoke.ts",
    "smoke:sync": "tsx src/sync-smoke.ts"
  },
  "dependencies": {
    "@pr-tracker/core": "workspace:*",
    "@pr-tracker/github": "workspace:*",
    "@mikro-orm/core": "^6.4.16",
    "@mikro-orm/migrations": "^6.4.16",
    "@mikro-orm/postgresql": "^6.4.16"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
