{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PR Tracker",
  "version": "0.1.0",
  "identifier": "dev.pr-tracker.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PR Tracker",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pr-tracker.sqlite"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
