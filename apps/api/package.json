{
  "name": "@pr-tracker/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --out-dir dist --clean",
    "start": "node dist/index.js",
    "db:smoke": "tsx src/db-smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@pr-tracker/core": "workspace:*",
    "@pr-tracker/db": "workspace:*",
    "@pr-tracker/github": "workspace:*",
    "@pr-tracker/reviewer-workflow": "workspace:*",
    "hono": "^4.7.11",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
