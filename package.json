{
  "name": "pr-tracker",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "pnpm build:packages && pnpm --filter @pr-tracker/desktop desktop:dev",
    "build:packages": "pnpm --filter @pr-tracker/core --filter @pr-tracker/github --filter @pr-tracker/db --filter @pr-tracker/reviewer-workflow build",
    "dev:desktop": "pnpm build:packages && pnpm --filter @pr-tracker/desktop desktop:dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "sample-data": "tsx scripts/sample-data.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
